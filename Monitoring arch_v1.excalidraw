      "seed": 277734620,
      "version": 615,
      "versionNonce": 1759704234,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "lk4iatI4BKpD_Jvb4SFSQ",
          "type": "arrow"
        }
      ],
      "updated": 1740517538924,
      "link": null,
      "locked": false,
      "text": "to protect against zonal failure->deploy across multiple zones \nwhat happens when a zone goes down\n ✅ If You Use FSLogix + Azure Files (ZRS)\n  ✔ users connected to the failed zone lose their connection, reconnection is required, and they must signin again.\n  ✔ If Fslogix is used and stored in ZRS, the profile is intact, allowing them to reconnect to another session host in different zone with minimal data loss\n  ✔ Failover from zonal failure is automatic, users just need to reconnect\n ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "to protect against zonal failure->deploy across multiple zones \nwhat happens when a zone goes down\n ✅ If You Use FSLogix + Azure Files (ZRS)\n  ✔ users connected to the failed zone lose their connection, reconnection is required, and they must signin again.\n  ✔ If Fslogix is used and stored in ZRS, the profile is intact, allowing them to reconnect to another session host in different zone with minimal data loss\n  ✔ Failover from zonal failure is automatic, users just need to reconnect\n ",
      "autoResize": true,
      "lineHeight": 1.25
    },
