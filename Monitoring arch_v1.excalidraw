    {
      "id": "l0CvyZz7veJJR16bKj5Ne",
      "type": "text",
      "x": 1152.977786593967,
      "y": 4382.459373219806,
      "width": 697.2005004882812,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
